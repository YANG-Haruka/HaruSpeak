# Python
__pycache__/
*.pyc
*.pyo
.venv/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Node
node_modules/
.next/
out/
*.log
*.tsbuildinfo

# PyInstaller / portable-app build artifacts
dist/
build/
scripts/_ffmpeg/
scripts/_cache/

# Personal scratch files (often contain API keys for ad-hoc testing)
test.py
scratch.py
*_scratch.py

# User state (config with API keys, logs, downloaded models — all big or sensitive)
# Note: `config/*` (not `config/`) so git still recurses and honors the
# negation below for the sample template.
config/*
!config/config.sample.json
logs/
models/

# Model weight formats (just in case anything leaks outside models/)
*.onnx
*.pt
*.safetensors

# IDE
.vscode/
.idea/
.claude/
*.swp
.DS_Store